root = true

[*]
charset = utf-8
end_of_line = lf
indent_size = 2
indent_style = space
trim_trailing_whitespace = true
insert_final_newline = true

[*.md]
max_line_length = off
trim_trailing_whitespace = false

[*.html]
indent_style = space
indent_size = 2
max_line_length = off

[*.htm]
indent_style = space
indent_size = 2
max_line_length = off

[*.toml]
max_line_length = off

[*.yaml]
max_line_length = off

[*.yml]
max_line_length = off
